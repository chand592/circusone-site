---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SectionHeading from '@components/SectionHeading.astro';
import CTABand from '@components/CTABand.astro';

interface Project {
  title: string;
  category: string;
  client: string;
  year: string;
  hue: string;
}

const projects: Project[] = [
  { title: 'Heritage Pack', category: 'Packaging', client: 'Royal Salute', year: '2023', hue: '12' },
  { title: 'Pop-up Showcase', category: 'Display', client: 'Perrier Jouët', year: '2023', hue: '280' },
  { title: 'Brand Refresh', category: 'Branding', client: 'Martell', year: '2022', hue: '30' },
  { title: 'Limited Edition', category: 'Packaging', client: 'Chivas', year: '2023', hue: '45' },
  { title: 'Property Campaign', category: 'Advertising', client: 'Savills', year: '2024', hue: '210' },
  { title: 'Window Installation', category: 'Display', client: 'Absolut', year: '2022', hue: '200' },
  { title: 'Range Refresh', category: 'Packaging', client: 'Penfolds', year: '2023', hue: '350' },
  { title: 'Launch Event', category: 'Event', client: 'Sun Hung Kai', year: '2024', hue: '230' },
  { title: 'Seasonal Display', category: 'Display', client: 'Lindt', year: '2023', hue: '20' },
  { title: 'Tourism Campaign', category: 'Advertising', client: 'HKTB', year: '2022', hue: '180' },
  { title: 'Brand Film', category: 'Multimedia', client: 'Mumm', year: '2023', hue: '350' },
  { title: 'Label Series', category: 'Packaging', client: 'Wolf Blass', year: '2022', hue: '0' },
];

const categories = ['All', 'Branding', 'Packaging', 'Display', 'Advertising', 'Event', 'Multimedia'];
---

<Base
  title="Portfolio — Circus One Limited"
  description="Selected work from Circus One Limited — branding, packaging, 3D display, advertising, events, and multimedia for clients from luxury spirits to local businesses."
>
  <Hero
    number="01"
    label="Selected work"
    title="Design that"
    highlight="earns its keep."
    lead="A rotating selection of recent projects. Filter by discipline, or scroll through the full range — every piece is the result of a relationship, not a one-off."
    primaryCta={{ label: 'Start a Project', href: '/contact' }}
    secondaryCta={{ label: 'Our Services', href: '/services' }}
  />

  <!-- Portfolio grid on flat deepred -->
  <section class="section-pad bg-deepred text-cream">
    <div class="container-content">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionHeading
          number="02"
          label="The work"
          title="Recent projects."
          variant="dark"
        />

        <!-- Filter chips — quiet, no pill-busy look -->
        <div class="flex flex-wrap gap-x-6 gap-y-2" id="filter-bar">
          {categories.map((c, i) => (
            <button
              type="button"
              data-filter={c}
              class={`text-xs uppercase tracking-[0.18em] pb-1 border-b transition-colors duration-200 ${
                i === 0
                  ? 'border-gold text-gold'
                  : 'border-transparent text-cream/45 hover:text-cream'
              }`}
            >
              {c}
            </button>
          ))}
        </div>
      </div>

      <div id="project-grid" class="mt-14 grid gap-px bg-cream/10 border border-cream/10 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((p) => (
          <div data-category={p.category} class="project-item bg-deepred">
            <ProjectCard {...p} variant="dark" />
          </div>
        ))}
      </div>

      <p id="empty-state" class="mt-12 hidden text-center text-sm text-cream/50">
        No projects in this category yet.
      </p>
    </div>
  </section>

  <!-- Capabilities strip -->
  <section class="section-pad bg-cream">
    <div class="container-content">
      <SectionHeading
        number="03"
        label="Capabilities"
        title="What goes into each project."
        lead="Disciplines overlap. A packaging brief often becomes a display brief; a brand refresh usually needs photography to land."
        align="center"
      />

      <div class="mt-12 grid gap-px bg-deepred/10 border border-deepred/10 md:grid-cols-3">
        <div class="bg-cream-50 p-8">
          <span class="rule-gold block mb-5"></span>
          <h3 class="heading-md text-deepred">Strategy-led</h3>
          <p class="prose-body mt-3">Every project starts with goals and audience — not aesthetics. We design to outcomes.</p>
        </div>
        <div class="bg-cream-50 p-8">
          <span class="rule-gold block mb-5"></span>
          <h3 class="heading-md text-deepred">In-house craft</h3>
          <p class="prose-body mt-3">Seven disciplines under one roof. No briefs lost in translation between agencies.</p>
        </div>
        <div class="bg-cream-50 p-8">
          <span class="rule-gold block mb-5"></span>
          <h3 class="heading-md text-deepred">Production-ready</h3>
          <p class="prose-body mt-3">We deliver files vendors can use, and we liaise with production when needed. No hand-off cliffs.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    title="Have a project in mind?"
    lead="We're always happy to talk through a brief — even if it's early and uncertain. Especially then, in fact."
    ctaLabel="Start a Conversation"
    ctaHref="/contact"
  />
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('#filter-bar [data-filter]');
  const items = document.querySelectorAll<HTMLElement>('#project-grid .project-item');
  const emptyState = document.getElementById('empty-state');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove('border-gold', 'text-gold');
        b.classList.add('border-transparent', 'text-cream/45');
      });
      btn.classList.add('border-gold', 'text-gold');
      btn.classList.remove('border-transparent', 'text-cream/45');

      let visibleCount = 0;
      items.forEach((item) => {
        const matches = filter === 'All' || item.dataset.category === filter;
        item.classList.toggle('hidden', !matches);
        if (matches) visibleCount++;
      });

      emptyState?.classList.toggle('hidden', visibleCount > 0);
    });
  });
</script>
