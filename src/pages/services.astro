---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ServiceCard from '@components/ServiceCard.astro';
import CTABand from '@components/CTABand.astro';

const serviceGroups = [
  {
    index: '01',
    title: 'Brand Building & Corporate ID',
    description: 'Identity systems and corporate branding that turn businesses into recognisable standards. We design the marks, systems, and guidelines that scale a brand across every touchpoint.',
    deliverables: ['Logo & identity design', 'Brand guidelines & systems', 'Visual language & typography', 'Brand strategy & positioning', 'Collateral templates'],
  },
  {
    index: '02',
    title: 'Product Packaging',
    description: 'Packaging that protects, persuades, and stands out on the shelf — from luxury spirit bottles to FMCG. We handle structural design, artwork, dielines, and production liaison.',
    deliverables: ['Structural packaging design', 'Label & bottle artwork', 'Dielines & print specs', 'Production & vendor liaison', 'Limited edition & gift sets'],
  },
  {
    index: '03',
    title: 'Display & Showcases (3D)',
    description: 'Three-dimensional displays, showcases, and shop navigation crafted to draw the eye and tell a story in physical space. From single POS units to full retail environments.',
    deliverables: ['POS & counter displays', 'Showcase & cabinet units', 'Shop navigation & wayfinding', 'Event & exhibition booths', 'Window installations'],
  },
  {
    index: '04',
    title: 'Web & Multimedia',
    description: 'Websites and multimedia experiences that extend your brand into digital with the same craft as the physical. Built fast, accessible, and on-brand.',
    deliverables: ['Website design & build', 'Interactive multimedia', 'Brand & product films', 'Motion graphics', 'Digital campaigns'],
  },
  {
    index: '05',
    title: 'Advertising & Collateral',
    description: 'Print and digital advertising, brochures, catalogues, and marketing collateral — designed to perform across channels while staying unmistakably on-brand.',
    deliverables: ['Print & press ads', 'Brochures & catalogues', 'Direct mail & flyers', 'Digital ad creative', 'Sales kits & presentations'],
  },
  {
    index: '06',
    title: 'Events & Exhibitions',
    description: 'End-to-end event production and exhibition design. We translate brand stories into immersive physical experiences — from trade booths to product launches.',
    deliverables: ['Exhibition booths & stands', 'Product launch events', 'Trade show presence', 'Brand activations', 'Event production management'],
  },
  {
    index: '07',
    title: 'Photography',
    description: 'Art direction and production photography that captures products, spaces, and brand moments — shot to elevate the design work it accompanies.',
    deliverables: ['Product photography', 'Lifestyle & campaign shoots', 'Architecture & interior', 'Event coverage', 'Retouching & art direction'],
  },
];

const process = [
  { step: '01', title: 'Discover', text: 'We start with the business, not the brief. Goals, audience, constraints, history.' },
  { step: '02', title: 'Define', text: 'Strategy and direction locked before any visual work begins. No surprises later.' },
  { step: '03', title: 'Design', text: 'Concepts, iterations, and refinement — crafted in-house across every discipline.' },
  { step: '04', title: 'Deliver', text: 'Production-ready assets, vendor liaison, and rollout support. We don\'t hand over and disappear.' },
];
---

<Base
  title="Services — Circus One Limited"
  description="Brand building, packaging, 3D display, web, advertising, events, and photography — seven disciplines under one Hong Kong roof."
>
  <Hero
    number="01"
    label="What we do"
    title="Seven disciplines."
    highlight="One standard."
    lead="Every service Circus One offers is delivered in-house by the same team that has shaped Hong Kong brands for over 30 years. Explore the full range below."
    primaryCta={{ label: 'Discuss a Project', href: '/contact' }}
    secondaryCta={{ label: 'See the Work', href: '/portfolio' }}
  />

  <!-- Services grid -->
  <section class="section-pad bg-cream">
    <div class="container-content">
      <SectionHeading
        number="02"
        label="Our services"
        title="From sketch to showcase."
        lead="Pick a single discipline or combine them — most of our long-term clients work with us across several."
      />

      <div class="mt-14 grid gap-px bg-deepred/10 border border-deepred/10 md:grid-cols-2 lg:grid-cols-3">
        {serviceGroups.map((s) => (
          <ServiceCard {...s} href="/contact" />
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section-pad bg-cream-200/40 border-y border-deepred/10">
    <div class="container-content">
      <SectionHeading
        number="03"
        label="How we work"
        title="A process built on relationships."
        lead="The same four steps, whether it's a single label or a full brand refresh."
        align="center"
      />

      <div class="mt-14 grid gap-px bg-deepred/10 border border-deepred/10 md:grid-cols-2 lg:grid-cols-4">
        {process.map((p) => (
          <div class="bg-cream-50 p-7 md:p-8">
            <div class="font-display text-2xl font-medium text-gold tnum">{p.step}</div>
            <span class="rule-gold mt-4"></span>
            <h3 class="mt-4 text-base font-medium text-deepred">{p.title}</h3>
            <p class="prose-body mt-2">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Need a discipline we haven't listed?"
    lead="We handle plenty of one-off briefs. Tell us what you're trying to achieve and we'll say honestly whether we're the right fit."
    ctaLabel="Talk to Us"
    ctaHref="/contact"
  />
</Base>
