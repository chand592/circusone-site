---
// Formspree-powered contact form.
// REPLACE the action URL with your own Formspree endpoint:
//   1. Create a free form at https://formspree.io
//   2. Copy the form ID (e.g. "abcdwxyz")
//   3. Replace the placeholder below with https://formspree.io/f/abcdwxyz
const formAction = 'https://formspree.io/f/your-form-id';

const serviceOptions = [
  'Brand Building & Corporate ID',
  'Product Packaging',
  'Display & Showcases (3D)',
  'Web & Multimedia',
  'Advertising & Collateral',
  'Events & Exhibitions',
  'Photography',
  'Not sure yet — let\'s talk',
];
---

<form action={formAction} method="POST" class="space-y-6">
  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <label for="name" class="field-label">Full name</label>
      <input id="name" name="name" type="text" required class="field-input" placeholder="Jane Doe" />
    </div>
    <div>
      <label for="email" class="field-label">Email</label>
      <input id="email" name="email" type="email" required class="field-input" placeholder="jane@company.com" />
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <label for="company" class="field-label">Company</label>
      <input id="company" name="company" type="text" class="field-input" placeholder="Company Ltd." />
    </div>
    <div>
      <label for="phone" class="field-label">Phone</label>
      <input id="phone" name="phone" type="tel" class="field-input" placeholder="+852 ..." />
    </div>
  </div>

  <div>
    <label for="service" class="field-label">What do you need help with?</label>
    <select id="service" name="service" class="field-input">
      {serviceOptions.map((opt) => (
        <option value={opt}>{opt}</option>
      ))}
    </select>
  </div>

  <div>
    <label for="message" class="field-label">Tell us about your project</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="field-textarea"
      placeholder="A few words about scope, timing, and goals..."
    ></textarea>
  </div>

  <!-- Honeypot for spam protection (Formspree) -->
  <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

  <div class="flex flex-wrap items-center gap-4 pt-2">
    <button type="submit" class="btn-primary">
      Send Message
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </button>
    <p class="text-xs text-heritage">
      We typically reply within 1–2 business days.
    </p>
  </div>
</form>
