---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Clients', href: '/clients' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-deepred/10 bg-cream transition-colors duration-200"
>
  <div class="container-content flex h-20 items-center justify-between gap-6">
    <!-- Logo — multiply blend removes the white background against cream -->
    <a href="/" class="flex items-center gap-3 shrink-0" aria-label="Circus One Limited — home">
      <img
        src="/logo.png"
        alt="Circus One Limited"
        width="180"
        height="56"
        class="h-9 w-auto md:h-11"
        style="mix-blend-mode: multiply;"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-9" aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link" data-active={isActive(item.href)}>
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href="/contact" class="hidden lg:inline-flex btn-primary !py-2.5 !px-5 text-xs">
      Start a Project
    </a>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      class="lg:hidden inline-flex h-10 w-10 items-center justify-center border border-deepred/20 text-deepred"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-deepred/10 bg-cream"
  >
    <nav class="container-content flex flex-col gap-1 py-6" aria-label="Mobile">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="border-b border-deepred/5 px-1 py-3 text-base font-medium text-deepred/80 transition-colors hover:text-deepred"
          data-active={isActive(item.href)}
        >
          {item.label}
        </a>
      ))}
      <a href="/contact" class="btn-primary mt-5 self-start">Start a Project</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });
</script>
