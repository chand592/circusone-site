---
interface Props {
  index?: string;
  title: string;
  description: string;
  icon?: string;
  href?: string;
  deliverables?: string[];
}

const {
  index,
  title,
  description,
  href = '/services',
  deliverables = [],
} = Astro.props;
---

<article class="card group flex h-full flex-col p-7 md:p-8">
  {index && (
    <div class="font-display text-sm font-medium text-gold tabular-nums">{index}</div>
  )}

  <h3 class="heading-md mt-5 text-deepred">{title}</h3>
  <p class="prose-body mt-3 flex-1">{description}</p>

  {deliverables.length > 0 && (
    <ul class="mt-5 border-t border-deepred/10 pt-5 text-sm text-heritage">
      {deliverables.slice(0, 4).map((d) => (
        <li class="flex items-start gap-3 py-1">
          <span class="mt-2 inline-block h-px w-3 bg-gold shrink-0"></span>
          <span>{d}</span>
        </li>
      ))}
    </ul>
  )}

  <a
    href={href}
    class="mt-7 btn-link self-start text-xs uppercase tracking-[0.18em] group/link"
  >
    Explore
    <svg class="h-3.5 w-3.5 text-gold opacity-0 -translate-x-1 transition-all duration-200 group-hover/link:opacity-100 group-hover/link:translate-x-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </a>
</article>
