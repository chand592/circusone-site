---
interface Props {
  number?: string;
  label?: string;
  title: string;
  highlight?: string;
  lead: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  number = '01',
  label = 'Est. 1992 — Hong Kong',
  title,
  highlight,
  lead,
  primaryCta = { label: 'View Our Work', href: '/portfolio' },
  secondaryCta = { label: 'Start a Project', href: '/contact' },
} = Astro.props;
---

<section class="bg-deepred text-cream">
  <div class="container-content py-24 md:py-32 lg:py-40">
    <div class="max-w-3xl">
      <div class="section-label !text-gold">
        <span class="section-label-num">{number}</span>
        <span>{label}</span>
      </div>

      <h1 class="heading-xl mt-8 text-cream text-balance">
        {title}
        {highlight && (
          <>
            {' '}
            <em class="not-italic text-gold font-normal">{highlight}</em>
          </>
        )}
      </h1>

      <p class="prose-lead mt-8 !text-cream/65 max-w-xl text-pretty">{lead}</p>

      <div class="mt-12 flex flex-wrap items-center gap-4">
        <a href={primaryCta.href} class="btn-on-dark">{primaryCta.label}</a>
        <a
          href={secondaryCta.href}
          class="btn-link-on-dark"
        >
          {secondaryCta.label}
        </a>
      </div>

      <!-- Trust strip with gold dot separators -->
      <div class="mt-20 border-t border-cream/10 pt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-xs uppercase tracking-[0.18em] text-cream/55">
        <span class="text-gold">Trusted by</span>
        <span>Martell</span>
        <span class="text-gold/70">·</span>
        <span>Royal Salute</span>
        <span class="text-gold/70">·</span>
        <span>Savills</span>
        <span class="text-gold/70">·</span>
        <span>Sun Hung Kai</span>
        <span class="text-gold/70">·</span>
        <span>Lindt</span>
        <span class="text-gold/70">·</span>
        <span class="text-cream/35">&amp; others</span>
      </div>
    </div>
  </div>
</section>
