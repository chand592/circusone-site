---
interface Props {
  title?: string;
  lead?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title = 'Let\'s build something memorable.',
  lead = 'From luxury spirits to local heroes — we add value to your brand at every touchpoint.',
  ctaLabel = 'Start a Project',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="bg-deepred text-cream">
  <div class="container-content py-20 md:py-28">
    <div class="max-w-2xl">
      <span class="rule-gold block"></span>
      <h2 class="heading-lg mt-6 text-cream text-balance">{title}</h2>
      <p class="prose-lead mt-5 !text-cream/65 text-pretty">{lead}</p>
      <a href={ctaHref} class="btn-on-dark mt-9">{ctaLabel}</a>
    </div>
  </div>
</section>
