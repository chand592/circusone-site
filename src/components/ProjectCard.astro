---
interface Props {
  title: string;
  category: string;
  client: string;
  year?: string;
  variant?: 'dark' | 'light';
  hue?: string;
}

const {
  title,
  category,
  client,
  year = '2024',
  variant = 'dark',
  hue = '210',
} = Astro.props;

const isDark = variant === 'dark';
---

<article class={`group block ${isDark ? 'card-dark' : 'card'}`}>
  <!-- Placeholder plate — REPLACE with real project imagery.
       A flat, muted colour block reads more like a printed portfolio plate
       than a gradient hero. -->
  <div
    class="relative aspect-[4/5] w-full overflow-hidden"
    style={`background: hsl(${hue} 22% 20%);`}
  >
    <div class="absolute inset-0 flex flex-col justify-between p-5">
      <span class={`text-[10px] font-medium uppercase tracking-[0.2em] ${isDark ? 'text-cream/55' : 'text-cream/55'}`}>
        {category}
      </span>
      <span class="font-display text-3xl font-medium text-cream/85 leading-none">
        {client}
      </span>
    </div>
    <!-- thin gold rule at top — lengthens on hover -->
    <span class="absolute left-5 top-12 h-px w-8 bg-gold/70 transition-all duration-300 group-hover:w-16"></span>
  </div>

  <div class={`p-5 border-t ${isDark ? 'border-cream/10 text-cream' : 'border-deepred/10 text-deepred'}`}>
    <div class={`text-[11px] uppercase tracking-[0.18em] ${isDark ? 'text-gold' : 'text-terracotta'}`}>
      {client} — {year}
    </div>
    <h3 class="mt-1.5 text-[15px] font-medium leading-snug">{title}</h3>
  </div>
</article>
