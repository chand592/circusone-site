---
interface Props {
  stat: string;
  label: string;
}

const { stat, label } = Astro.props;
---

<div>
  <span class="block h-px w-8 bg-gold mb-4"></span>
  <div class="font-display text-4xl font-medium text-deepred tnum md:text-5xl">{stat}</div>
  <div class="mt-2 text-xs font-medium uppercase tracking-[0.18em] text-heritage">{label}</div>
</div>
