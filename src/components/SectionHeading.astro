---
interface Props {
  number?: string;
  label?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
  variant?: 'light' | 'dark';
}

const {
  number,
  label,
  title,
  lead,
  align = 'left',
  variant = 'light',
} = Astro.props;

const isCenter = align === 'center';
const isDark = variant === 'dark';
---

<div class={isCenter ? 'mx-auto max-w-2xl text-center' : 'max-w-2xl'}>
  {label && (
    <div class={`section-label ${isCenter ? 'justify-center' : ''} ${isDark ? '!text-gold' : ''}`}>
      {number && <span class="section-label-num">{number}</span>}
      <span>{label}</span>
    </div>
  )}
  {isDark && <span class="rule-gold mt-5"></span>}
  <h2 class={`heading-lg ${isDark ? 'mt-5' : 'mt-4'} text-balance ${isDark ? 'text-cream' : 'text-deepred'}`}>
    {title}
  </h2>
  {lead && (
    <p class={`prose-lead mt-5 text-pretty ${isDark ? '!text-cream/65' : ''}`}>{lead}</p>
  )}
</div>
