---
const year = new Date().getFullYear();

const footerNav = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Clients', href: '/clients' },
  { label: 'Contact', href: '/contact' },
];

const services = [
  'Brand Building & Corporate ID',
  'Product Packaging',
  'Display & Showcases',
  'Web & Multimedia',
  'Advertising & Collateral',
  'Events & Exhibitions',
  'Photography',
];
---

<footer class="bg-deepred text-cream">
  <div class="container-content py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      <!-- Brand block -->
      <div class="lg:col-span-1">
        <!-- Logo on a refined cream plate: gold hairline border + gold underline
             accent so it reads as a deliberate brand sign-off, not a stuck-on box.
             multiply blend keeps the logo's white background invisible on cream. -->
        <div class="inline-block">
          <div class="bg-cream px-5 py-3.5 rounded-sm border border-gold/25">
            <img
              src="/logo.png"
              alt="Circus One Limited"
              width="160"
              height="50"
              class="h-9 w-auto block"
              style="mix-blend-mode: multiply;"
            />
          </div>
          <span class="mt-2 block h-px w-full bg-gold/50"></span>
        </div>
        <p class="mt-6 text-sm leading-relaxed text-cream/65 max-w-xs">
          <!-- REPLACE: footer tagline -->
          Adding values to all business since 1992. Design and marketing partners
          for brands from luxury spirits to local heroes.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.18em] text-gold">Explore</h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {footerNav.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-cream/65 transition-colors hover:text-cream"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.18em] text-gold">Services</h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {services.map((s) => (
            <li class="text-cream/65">{s}</li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.18em] text-gold">Contact</h3>
        <address class="mt-5 space-y-3 text-sm not-italic text-cream/65 leading-relaxed">
          <p>
            No 203–208, 1/F New Mandarin Plaza<br />
            14 Science Museum Road, Tsimshatsui<br />
            Kowloon, Hong Kong
          </p>
          <p>
            <a href="tel:+85225034581" class="transition-colors hover:text-cream">t +852 2503 4581</a><br />
            f +852 2503 4616<br />
            <a href="mailto:info@circusone.com" class="transition-colors hover:text-cream">info@circusone.com</a>
          </p>
        </address>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-cream/10 pt-6 text-xs text-cream/45 md:flex-row md:items-center">
      <p>&copy; {year} Circus One Limited. All rights reserved.</p>
      <p>Design &amp; marketing partners · est. 1992 · Hong Kong</p>
    </div>
  </div>
</footer>
