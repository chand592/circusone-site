---
interface Props {
  name: string;
  variant?: 'dark' | 'light';
}

const { name, variant = 'light' } = Astro.props;
const isDark = variant === 'dark';
---

<div
  class={`group flex h-14 items-center justify-center border ${isDark ? 'border-cream/15 text-cream/55 hover:text-cream hover:border-gold/50' : 'border-deepred/12 text-deepred/55 hover:text-deepred hover:border-gold/60'} transition-colors duration-200 px-4 relative`}
>
  <span class="font-display text-[15px] font-medium tracking-wide">{name}</span>
  <span class="pointer-events-none absolute bottom-0 left-1/2 h-px w-0 -translate-x-1/2 bg-gold transition-all duration-300 group-hover:w-8"></span>
</div>
